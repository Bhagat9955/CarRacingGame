        void CreateInitialEnemies()
        {
            // Create 3 enemies with large spacing between them
            int[] startPositions = { -150, -350, -550 };
            int[] lanes = { 120, 170, 220 };

            // Shuffle lanes to randomize initial positions
            ShuffleArray(lanes);

            for (int i = 0; i < 3; i++)
            {
                PictureBox enemy = new PictureBox();
                enemy.Image = DrawEnemyCar(GetRandomCarColor());
                enemy.Size = new Size(60, 110);
                enemy.SizeMode = PictureBoxSizeMode.StretchImage;
                enemy.Location = new Point(lanes[i], startPositions[i]);
                enemy.BackColor = Color.Transparent;
                this.Controls.Add(enemy);
                enemies.Add(enemy);
            }
        }

        void ShuffleArray(int[] array)
        {
            for (int i = array.Length - 1; i > 0; i--)
            {
                int j = rand.Next(i + 1);
                int temp = array[i];
                array[i] = array[j];
                array[j] = temp;
            }
        }

        // Get available lane that's not too close to other enemies
        int GetAvailableLane(int currentY)
        {
            List<int> availableLanes = new List<int> { 120, 170, 220 };

            // Remove lanes that have enemies too close vertically
            foreach (var enemy in enemies)
            {
                if (Math.Abs(enemy.Top - currentY) < minDistanceBetweenEnemies)
                {
                    availableLanes.Remove(enemy.Left);
                }
            }

            // If no lanes available, return random lane
            if (availableLanes.Count == 0)
                return new int[] { 120, 170, 220 }[rand.Next(3)];

            return availableLanes[rand.Next(availableLanes.Count)];
        }

        // Check if position is safe (not overlapping with other enemies)
        bool IsPositionSafe(int x, int y, PictureBox excludeEnemy = null)
        {
            Rectangle newBounds = new Rectangle(x, y, 60, 110);

            foreach (var enemy in enemies)
            {
                if (enemy == excludeEnemy) continue;

                // Check vertical spacing
                if (Math.Abs(enemy.Top - y) < minDistanceBetweenEnemies)
                {
                    return false;
                }

                // Check horizontal spacing (if too close vertically)
                if (Math.Abs(enemy.Top - y) < 150 && Math.Abs(enemy.Left - x) < 60)
                {
                    return false;
                }
            }
            return true;
        }

        // 🚗 MOVE PLAYER WITH COLLISION PREDICTION
        void MovePlayerWithPrediction(object sender, KeyEventArgs e)
        {
            if (collisionCooldown > 0) return;

            int newLeft = player.Left;

            if (e.KeyCode == Keys.Left && player.Left > 100)
                newLeft = player.Left - 20;
            else if (e.KeyCode == Keys.Right && player.Right < 300)
                newLeft = player.Left + 20;
            else
                return;

            // Check future collisions
            bool willCollide = false;

            for (int frame = 1; frame <= PREDICTION_FRAMES; frame++)
            {
                Rectangle predictedPlayer = new Rectangle(newLeft, player.Top, player.Width, player.Height);

                foreach (var enemy in enemies)
                {
                    Rectangle predictedEnemy = new Rectangle(enemy.Left, enemy.Top + (speed * frame), enemy.Width, enemy.Height);

                    if (predictedPlayer.IntersectsWith(predictedEnemy))
                    {
                        willCollide = true;
                        break;
                    }
                }
                if (willCollide) break;
            }

            if (!willCollide)
            {
                player.Left = newLeft;
                player.Image = DrawPlayerCar();
                player.BackColor = Color.Transparent;
            }
            else
            {
                player.BackColor = Color.FromArgb(100, Color.Red);
                ShowWarning("⚠️ PATH BLOCKED! ⚠️");
                System.Media.SystemSounds.Beep.Play();
            }
        }

