        // 🔁 GAME LOOP
        void GameLoop(object sender, EventArgs e)
        {
            score++;
            scoreLabel.Text = "Score: " + score;

            // Update collision cooldown
            if (collisionCooldown > 0)
            {
                collisionCooldown--;
                if (collisionCooldown % 5 == 0)
                    player.Visible = !player.Visible;
                else
                    player.Visible = true;

                if (collisionCooldown == 0)
                {
                    player.BackColor = Color.Transparent;
                    player.Visible = true;
                }
            }

            // Speed scaling
            if (currentMode == "EASY")
                speed = baseSpeed + (score / 300);
            else if (currentMode == "MEDIUM")
                speed = baseSpeed + (score / 200);
            else if (currentMode == "HARD")
                speed = baseSpeed + (score / 150);

            if (speed > 18) speed = 18;

            // Move all enemies
            for (int i = enemies.Count - 1; i >= 0; i--)
            {
                var enemy = enemies[i];
                enemy.Top += speed;

                // Respawn enemy at top with proper spacing
                if (enemy.Top > this.Height)
                {
                    int newLane = GetAvailableLane(-100);
                    int newY = -150;

                    // Ensure spacing from other enemies
                    while (!IsPositionSafe(newLane, newY, enemy) && newY > -500)
                    {
                        newY -= 50;
                    }

                    enemy.Left = newLane;
                    enemy.Top = newY;
                    enemy.Image = DrawEnemyCar(GetRandomCarColor());
                }
            }

            // COLLISION DETECTION with cooldown
            if (collisionCooldown == 0)
            {
                foreach (var enemy in enemies)
                {
                    if (player.Bounds.IntersectsWith(enemy.Bounds))
                    {
                        GameOver();
                        return;
                    }
                }

                // Near miss detection
                Rectangle extendedBounds = new Rectangle(player.Left - 15, player.Top - 15,
                                                          player.Width + 30, player.Height + 30);

                foreach (var enemy in enemies)
                {
                    if (extendedBounds.IntersectsWith(enemy.Bounds))
                    {
                        int bonus = 20;
                        score += bonus;
                        scoreLabel.Text = "Score: " + score;
                        collisionCooldown = COLLISION_COOLDOWN_MAX / 2;
                        player.BackColor = Color.FromArgb(100, Color.Gold);

                        ShowBonus($"+{bonus} NEAR MISS!");
                        System.Media.SystemSounds.Asterisk.Play();
                        break;
                    }
                }
            }

            this.Refresh();
        }

