        // 🎨 Draw Player Car
        Bitmap DrawPlayerCar()
        {
            Bitmap bmp = new Bitmap(60, 110);
            using (Graphics g = Graphics.FromImage(bmp))
            {
                g.SmoothingMode = SmoothingMode.AntiAlias;

                LinearGradientBrush bodyBrush;
                if (collisionCooldown > 0)
                {
                    bodyBrush = new LinearGradientBrush(
                        new Point(0, 0), new Point(0, 110),
                        Color.Gold, Color.Orange);
                }
                else
                {
                    bodyBrush = new LinearGradientBrush(
                        new Point(0, 0), new Point(0, 110),
                        Color.DarkRed, Color.Red);
                }
                g.FillRectangle(bodyBrush, 10, 20, 40, 70);

                g.FillRectangle(Brushes.DarkBlue, 15, 10, 30, 25);
                g.FillRectangle(Brushes.LightBlue, 18, 13, 24, 18);
                g.FillRectangle(Brushes.LightSkyBlue, 15, 30, 12, 15);
                g.FillRectangle(Brushes.LightSkyBlue, 33, 30, 12, 15);

                g.FillEllipse(Brushes.Yellow, 12, 22, 6, 8);
                g.FillEllipse(Brushes.Yellow, 42, 22, 6, 8);
                g.FillEllipse(Brushes.Red, 12, 85, 6, 8);
                g.FillEllipse(Brushes.Red, 42, 85, 6, 8);

                g.FillEllipse(Brushes.Black, 8, 75, 12, 20);
                g.FillEllipse(Brushes.Black, 40, 75, 12, 20);
                g.FillEllipse(Brushes.Black, 8, 25, 12, 20);
                g.FillEllipse(Brushes.Black, 40, 25, 12, 20);

                if (collisionCooldown > 0)
                {
                    g.FillEllipse(Brushes.Gold, 10, 79, 8, 12);
                    g.FillEllipse(Brushes.Gold, 42, 79, 8, 12);
                    g.FillEllipse(Brushes.Gold, 10, 29, 8, 12);
                    g.FillEllipse(Brushes.Gold, 42, 29, 8, 12);
                }
                else
                {
                    g.FillEllipse(Brushes.Silver, 10, 79, 8, 12);
                    g.FillEllipse(Brushes.Silver, 42, 79, 8, 12);
                    g.FillEllipse(Brushes.Silver, 10, 29, 8, 12);
                    g.FillEllipse(Brushes.Silver, 42, 29, 8, 12);
                }

                using (Pen stripePen = new Pen(Color.White, 2))
                {
                    g.DrawLine(stripePen, 28, 20, 28, 90);
                }

                g.FillRectangle(Brushes.DarkRed, 20, 95, 20, 5);
            }
            return bmp;
        }

        // 🎨 Draw Enemy Car
        Bitmap DrawEnemyCar(Color carColor)
        {
            Bitmap bmp = new Bitmap(60, 110);
            using (Graphics g = Graphics.FromImage(bmp))
            {
                g.SmoothingMode = SmoothingMode.AntiAlias;

                LinearGradientBrush bodyBrush = new LinearGradientBrush(
                    new Point(0, 0), new Point(0, 110),
                    Color.FromArgb(100, carColor.R / 2, carColor.G / 2, carColor.B / 2),
                    carColor);
                g.FillRectangle(bodyBrush, 10, 20, 40, 70);

                g.FillRectangle(Brushes.Black, 15, 10, 30, 25);
                g.FillRectangle(Brushes.Gray, 18, 13, 24, 18);
                g.FillRectangle(Brushes.DarkSlateGray, 15, 30, 12, 15);
                g.FillRectangle(Brushes.DarkSlateGray, 33, 30, 12, 15);

                g.FillEllipse(Brushes.White, 12, 22, 6, 8);
                g.FillEllipse(Brushes.White, 42, 22, 6, 8);
                g.FillEllipse(Brushes.Red, 12, 85, 6, 8);
                g.FillEllipse(Brushes.Red, 42, 85, 6, 8);

                g.FillEllipse(Brushes.Black, 8, 75, 12, 20);
                g.FillEllipse(Brushes.Black, 40, 75, 12, 20);
                g.FillEllipse(Brushes.Black, 8, 25, 12, 20);
                g.FillEllipse(Brushes.Black, 40, 25, 12, 20);

                g.FillEllipse(Brushes.DarkGray, 10, 79, 8, 12);
                g.FillEllipse(Brushes.DarkGray, 42, 79, 8, 12);
                g.FillEllipse(Brushes.DarkGray, 10, 29, 8, 12);
                g.FillEllipse(Brushes.DarkGray, 42, 29, 8, 12);

                using (Pen stripePen = new Pen(Color.White, 2))
                {
                    g.DrawLine(stripePen, 12, 50, 48, 50);
                    g.DrawLine(stripePen, 12, 55, 48, 55);
                }
            }
            return bmp;
        }

        void DrawRoad(object sender, PaintEventArgs e)
        {
            Graphics g = e.Graphics;

            g.FillRectangle(Brushes.DarkGray, 80, 0, 240, this.Height);

            using (Pen edgePen = new Pen(Color.White, 4))
            {
                g.DrawLine(edgePen, 80, 0, 80, this.Height);
                g.DrawLine(edgePen, 320, 0, 320, this.Height);
            }

            using (Pen lanePen = new Pen(Color.Yellow, 3))
            {
                lanePen.DashStyle = DashStyle.Dash;
                lanePen.DashPattern = new float[] { 15, 15 };
                g.DrawLine(lanePen, 200, 0, 200, this.Height);
            }

            // Road markings
            for (int i = 0; i < 60; i++)
            {
                int x = 85 + (i % 230);
                int y = (score * 2 + i * 25) % this.Height;
                g.FillEllipse(Brushes.LightGray, x, y, 2, 2);
            }
        }

        Color GetRandomCarColor()
        {
            Color[] colors = { Color.Blue, Color.Green, Color.Purple,
                              Color.Orange, Color.DarkCyan, Color.Magenta };
            return colors[rand.Next(colors.Length)];
        }

        void GameOver()
        {
            gameTimer.Stop();
            player.Visible = true;

            string name = Microsoft.VisualBasic.Interaction.InputBox(
                "Enter Name:", "Game Over - Score: " + score, "Player");

            SaveScore(name, score, currentMode);
            ShowScores();

            if (MessageBox.Show("Play Again?", "Game Over", MessageBoxButtons.YesNo) == DialogResult.Yes)
                ShowModeSelection();
            else
                Application.Exit();
        }

        void SaveScore(string name, int score, string mode)
        {
            try
            {
                using (MySqlConnection conn = new MySqlConnection(connStr))
                {
                    conn.Open();
                    string q = "INSERT INTO scores(player_name, score, game_mode, date_played) VALUES(@n, @s, @m, NOW())";
                    MySqlCommand cmd = new MySqlCommand(q, conn);
                    cmd.Parameters.AddWithValue("@n", name);
                    cmd.Parameters.AddWithValue("@s", score);
                    cmd.Parameters.AddWithValue("@m", mode);
                    cmd.ExecuteNonQuery();
                }
            }
            catch { }
        }

        void ShowScores()
        {
            try
            {
                using (MySqlConnection conn = new MySqlConnection(connStr))
                {
                    conn.Open();
                    string q = "SELECT player_name, score, game_mode FROM scores ORDER BY score DESC LIMIT 5";
                    MySqlCommand cmd = new MySqlCommand(q, conn);
                    var r = cmd.ExecuteReader();

                    string s = "🏆 HIGH SCORES 🏆\n\n";
                    int rank = 1;
                    while (r.Read())
                    {
                        s += $"{rank}. {r[0]} - {r[1]} pts ({r[2]})\n";
                        rank++;
                    }

                    MessageBox.Show(s, "Leaderboard", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }
            catch { }
        }
